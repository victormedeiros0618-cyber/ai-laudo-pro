# IA-Laudo (VistorIA) — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local com valores reais.

# Supabase — obter em: https://supabase.com/dashboard > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API
VITE_API_URL=http://localhost:54321/functions/v1
VITE_ENV=development

# Stripe — obter em: https://dashboard.stripe.com/apikeys
# ATENÇÃO: usar APENAS a chave publicável (pk_*) — nunca a secret key no frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Gemini — NÃO deve estar aqui em produção
# Em produção, a chave fica APENAS nas Edge Functions (variável server-side)
# Obter em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIza...
